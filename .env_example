# =======================================
# Example environment file for LibrePlate
# =======================================

# TODO: Should probably be RELEASE=True, to be consistant with other scripts in
# this codebase.
# Enable Django debug mode.
# Leave this set to False in production.
DEBUG=False

# Secret key used by Django for cryptographic signing.
# Generate a new value with:
#
#   uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# Never reuse example keys or share this value publicly.
SECRET_KEY=

# Comma-separated list of hostnames that Django will serve.
# Examples:
#   ALLOWED_HOSTS=127.0.0.1,localhost
#   ALLOWED_HOSTS=example.com,www.example.com
ALLOWED_HOSTS=127.0.0.1

# PostgreSQL database connection string.
# Format:
#   postgres://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=

# Directory where collected static files will be written.
STATIC_ROOT=/var/www/libreplate/staticfiles

# Directory where media files will be stored.
MEDIA_ROOT=/var/www/libreplate/media